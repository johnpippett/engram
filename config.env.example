# Atlas Brain Configuration
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control.

# -- Your Name -------------------------------------------------
# Used in prompts and personalization
ATLAS_USER_NAME=User

# -- Timezone --------------------------------------------------
# IANA timezone string (e.g., America/New_York, Europe/London)
ATLAS_TIMEZONE=UTC

# -- Telegram Bot ----------------------------------------------
# Create a bot via @BotFather on Telegram
ATLAS_BOT_TOKEN=
ATLAS_CHAT_ID=
# Optional: Telegram thread ID for topic-based groups
# ATLAS_THREAD_ID=

# -- LLM API (OpenRouter-compatible endpoint) -----------------
# Default points to a local gateway; change to your provider
ATLAS_GATEWAY_URL=http://127.0.0.1:18789/v1/chat/completions
ATLAS_GATEWAY_TOKEN=

# -- Models ----------------------------------------------------
# OpenRouter model IDs (or any compatible provider)
ATLAS_MODEL=anthropic/claude-sonnet-4-6
ATLAS_DEEP_MODEL=anthropic/claude-opus-4-6

# -- Schedule --------------------------------------------------
# Reduced-interruption days (weekday numbers: 0=Mon, 6=Sun)
# Example: "2,4" = Wednesday and Friday
ATLAS_PARENTING_DAYS=2,4

# Quiet hours — no messages sent during this window
ATLAS_QUIET_START=22
ATLAS_QUIET_END=6

# -- Google Calendar (optional) --------------------------------
# Used by 'gog' CLI for calendar-aware scheduling
# Leave blank to use energy-window-only fallback
GOG_KEYRING_PASSWORD=
GOG_ACCOUNT=

# -- Session Transcript Path (optional) ------------------------
# Path to JSONL session transcripts for perception layer
# ATLAS_SESSIONS_DIR=~/.openclaw/agents/main/sessions
